# Supabase connection. Find both in your Supabase project under
# Project Settings → API. The anon key is safe to expose in the
# browser; security comes from the row level security policies
# in supabase.sql, not from hiding this key.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
